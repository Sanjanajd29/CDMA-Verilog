module cdma_tb ;
reg data1, data2;
wire out1, out2;

cdma_top uut(
    .data1(data1),
    .data2(data2),
    .data1_out(out1),
    .data2_out(out2)
);

initial begin
    $monitor("Time=%0t | d1=%b d2=%b | o1=%b o2=%b",
              $time, data1, data2, out1, out2);

    data1 = 0; data2 = 0; #10;
    data1 = 1; data2 = 0; #10;
    data1 = 0; data2 = 1; #10;
    data1 = 1; data2 = 1; #10;

    $finish;
end
endmodule
